# BetterGLM runtime configuration

# Model API
PHONE_AGENT_BASE_URL=https://open.bigmodel.cn/api/paas/v4
PHONE_AGENT_MODEL=autoglm-phone
PHONE_AGENT_API_KEY=replace-with-your-api-key

# Device mode: adb, hdc, or ios
PHONE_AGENT_DEVICE_TYPE=ios

# iOS WebDriverAgent
# USB + iproxy:
PHONE_AGENT_WDA_URL=http://localhost:8100

# WiFi WDA example:
# PHONE_AGENT_WDA_URL=http://10.20.1.147:8100

# Optional
PHONE_AGENT_MAX_STEPS=100
PHONE_AGENT_LANG=cn

# Optional replay logging. This stores screenshots, so keep it local.
# PHONE_AGENT_REPLAY_DIR=runs

# Optional local Web console.
BETTERGLM_WEB_HOST=127.0.0.1
BETTERGLM_WEB_PORT=8765
